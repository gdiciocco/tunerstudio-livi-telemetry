{
  "usbmon": {
    "decoder": "fixed_frame",
    "frame_length": 64,
    "endian": "big",
    "sync": "",
    "fields": [
      { "offset": 0, "type": "u16", "field": "rpm" },
      { "offset": 2, "type": "u16", "field": "speedKph", "scale": 0.1, "round": 1 },
      { "offset": 4, "type": "i16", "field": "coolantC", "scale": 0.1, "round": 1 },
      { "offset": 6, "type": "i16", "field": "iatC", "scale": 0.1, "round": 1 },
      { "offset": 8, "type": "u16", "field": "mapKpa", "scale": 0.1, "round": 1 },
      { "offset": 10, "type": "u16", "field": "batteryV", "scale": 0.01, "round": 2 },
      { "offset": 12, "type": "u16", "field": "lambda", "scale": 0.001, "round": 3 },
      { "offset": 14, "type": "i8", "field": "gear", "transform": "gear" },
      { "offset": 15, "type": "u8", "field": "lights", "bit": 0, "transform": "bool" },
      { "offset": 15, "type": "u8", "field": "highBeam", "bit": 1, "transform": "bool" },
      { "offset": 15, "type": "u8", "field": "hazards", "bit": 2, "transform": "bool" },
      { "offset": 16, "type": "u8", "field": "turn", "transform": "turn" },
      { "offset": 20, "type": "float32", "field": "gps.lat" },
      { "offset": 24, "type": "float32", "field": "gps.lng" },
      { "offset": 28, "type": "float32", "field": "gps.speedMs" }
    ]
  }
}

